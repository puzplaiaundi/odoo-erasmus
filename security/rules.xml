<odoo>
  <data noupdate="1">
    <!-- Portal users can only access their own Persona -->
    <record id="rule_portal_persona_own" model="ir.rule">
      <field name="name">Persona Erasmus: Portal Own</field>
      <field name="model_id" ref="model_erasmus_persona"/>
      <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
      <field name="domain_force">[("partner_id","=", user.partner_id.id)]</field>
    </record>

    <!-- Portal users can only access Movilidades of their Persona -->
    <record id="rule_portal_movilidad_own" model="ir.rule">
      <field name="name">Movilidad Erasmus: Portal Own</field>
      <field name="model_id" ref="model_erasmus_movilidad"/>
      <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
      <field name="domain_force">[("persona_id.partner_id","=", user.partner_id.id)]</field>
    </record>

    <!-- Profesores: ver solo sus alumnos (y su propia ficha si son persona=profesor) -->
    <record id="rule_profesor_persona_students" model="ir.rule">
      <field name="name">Persona Erasmus: Profesor ve sus alumnos</field>
      <field name="model_id" ref="model_erasmus_persona"/>
      <field name="groups" eval="[(4, ref('gestion_erasmus.group_erasmus_profesor'))]"/>
      <field name="domain_force">['|',
        '&amp;', ('tipo_interno', '=', 'estudiante'), ('profesor_user_id', '=', user.id),
        '&amp;', ('tipo_interno', '=', 'profesor'), ('user_id', '=', user.id)
      ]</field>
    </record>

    <!-- Admin: acceso total sin filtro -->
    <record id="rule_admin_persona_all" model="ir.rule">
      <field name="name">Persona Erasmus: Admin full access</field>
      <field name="model_id" ref="model_erasmus_persona"/>
      <field name="groups" eval="[(4, ref('gestion_erasmus.group_erasmus_admin'))]"/>
      <field name="domain_force">[(1,'=',1)]</field>
    </record>
  </data>
</odoo>
