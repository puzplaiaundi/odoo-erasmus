<odoo>
    <data>
        <!-- Añadir acceso en el dashboard del portal -->
        <template id="portal_my_home_erasmus" inherit_id="portal.portal_my_home">
          <xpath expr="//div[hasclass('o_portal_my_home')]" position="inside">
            <div class="row g-3 mt-2">
              <div class="col-12 col-md-6 col-lg-4">
                <a href="/my/erasmus" class="card h-100" style="text-decoration:none;">
                  <div class="card-body">
                    <h5 class="card-title">Mi Erasmus</h5>
                    <p class="card-text text-muted">Revisa tus datos y sube la documentación requerida.</p>
                  </div>
                </a>
              </div>
            </div>
          </xpath>
        </template>
