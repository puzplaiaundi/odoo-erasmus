<odoo>
  <data>

    <record id="view_users_form_inherit_erasmus_role" model="ir.ui.view">
      <field name="name">res.users.form.inherit.erasmus.role</field>
      <field name="model">res.users</field>
      <field name="inherit_id" ref="base.view_users_form"/>
      <field name="arch" type="xml">
        <xpath expr="//page[@name='access_rights']" position="inside">
          <group string="Erasmus" groups="base.group_system">
            <field name="erasmus_role"/>
          </group>
        </xpath>
      </field>
    </record>

  </data>
</odoo>